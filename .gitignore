# Agent / MCP caches — local-only
.serena/
.codex/
.cursor/

# Browser-history / research exports (leaked secrets risk)
data/safari/
docs/research/gemini_export.html
docs/research/*_export.html
docs/research/*_export.json

# Rust build artifacts
/target

# Orphaned lockfiles (no matching package.json at root)
/bun.lock
/Cargo.lock

# Nested lockfiles
rust/Cargo.lock
python/.venv/.lock
agileplus-mcp/.venv/.lock
crates/agileplus-dashboard/web/bun.lock

# Large runtime artifacts
spec_dags.json
crates/agileplus-dashboard/web/node_modules/
