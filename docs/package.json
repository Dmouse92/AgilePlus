{
  "name": "agileplus-docs",
  "version": "0.1.0",
  "private": true,
  "description": "AgilePlus documentation — spec-driven development engine",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:test:unit": "node --test tests/unit/*.test.mjs",
    "docs:test:component": "node --test tests/component/*.test.mjs",
    "docs:test:e2e": "playwright test --config tests/playwright.config.ts",
    "docs:test": "npm run docs:test:unit && npm run docs:test:component && npm run docs:test:e2e",
    "docs:check": "npm run docs:build && npm run docs:test",
    "lint": "oxlint -c ../oxlint.config.json ."
  },
  "dependencies": {
    "@phenotype/docs": "file:vendor/phenodocs/packages/docs",
    "vitepress": "^1.6.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "markdownlint-cli": "^0.48.0",
    "mermaid": "^11.12.3",
    "oxlint": "^0.15.11",
    "typescript": "^5.7.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
