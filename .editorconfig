# EditorConfig — AgilePlus
# https://editorconfig.org

root = true

# Universal defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Rust
[*.rs]
indent_size = 4
max_line_length = 100

# TOML
[*.toml]
indent_size = 2
max_line_length = 100

# Python
[*.py]
indent_size = 4
max_line_length = 88

# Shell scripts
[*.{sh,bash,zsh}]
indent_size = 2
max_line_length = 100

# Markdown
[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 120

# JSON / YAML
[*.{json,yml,yaml}]
indent_size = 2
max_line_length = 100

# Proto / Protobuf
[*.proto]
indent_size = 2
max_line_length = 100

# Justfile / Makefile
[{Justfile,justfile,Makefile}]
indent_style = tab
max_line_length = 100

# GitHub Actions
[.github/workflows/*.yml]
indent_size = 2
max_line_length = 100
