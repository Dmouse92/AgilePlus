root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.rs]
indent_size = 4
max_line_length = 100

[*.go]
indent_style = tab
indent_size = 4

[*.py]
indent_size = 4

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# --- appended by L2 #28 on 2026-06-11 ---
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{toml,yaml,yml,json,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
# trailing spaces in Markdown denote hard line breaks

[*.{zsh,sh,bash}]
indent_size = 2

[*.{diff,patch}]
trim_trailing_whitespace = false
